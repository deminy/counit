if (!version_compare(PHP_VERSION, PHP_VERSION, '=')) {
    fwrite(
        STDERR,
        sprintf(
            '%s declares an invalid value for PHP_VERSION.' . PHP_EOL .
            'This breaks fundamental functionality such as version_compare().' . PHP_EOL .
            'Please use a different PHP interpreter.' . PHP_EOL,

            PHP_BINARY
        )
    );

    die(1);
}

if (version_compare('7.2.0', PHP_VERSION, '>')) {
    fwrite(
        STDERR,
        sprintf(
            'This version of PHPUnit requires PHP >= 7.2.' . PHP_EOL .
            'You are using PHP %s (%s).' . PHP_EOL,
            PHP_VERSION,
            PHP_BINARY
        )
    );

    die(1);
}

foreach (['dom', 'json', 'libxml', 'mbstring', 'tokenizer', 'xml', 'xmlwriter'] as $extension) {
    if (extension_loaded($extension)) {
        continue;
    }

    fwrite(
        STDERR,
        sprintf(
            'PHPUnit requires the "%s" extension.' . PHP_EOL,
            $extension
        )
    );

    die(1);
}

if (!ini_get('date.timezone')) {
    ini_set('date.timezone', 'UTC');
}

foreach (array(__DIR__ . '/../../autoload.php', __DIR__ . '/../vendor/autoload.php', __DIR__ . '/vendor/autoload.php') as $file) {
    if (file_exists($file)) {
        define('PHPUNIT_COMPOSER_INSTALL', $file);

        break;
    }
}

unset($file);

if (!defined('PHPUNIT_COMPOSER_INSTALL')) {
    fwrite(
        STDERR,
        'You need to set up the project dependencies using Composer:' . PHP_EOL . PHP_EOL .
        '    composer install' . PHP_EOL . PHP_EOL .
        'You can learn all about Composer on https://getcomposer.org/.' . PHP_EOL
    );

    die(1);
}

$options = getopt('', array('prepend:'));

if (isset($options['prepend'])) {
    require $options['prepend'];
}

unset($options);

require PHPUNIT_COMPOSER_INSTALL;

// Swoole is enabled? Then try to run unit tests in parallel using different coroutines!
if (extension_loaded('swoole')) {
    Swoole\Coroutine::set(
        [
            // Swoole only honors hook flags configured before the coroutine scheduler starts, so
            // they must be set here rather than from inside a test. See
            // Deminy\Counit\Helper::coroutineHookFlags() for why STDIO/file hooks are excluded.
            'hook_flags'     => Deminy\Counit\Helper::coroutineHookFlags(),
            'exit_condition' => function (): bool {
                return Swoole\Coroutine::stats()['coroutine_num'] === 0;
            },
        ]
    );

    $code = 0;
    Swoole\Coroutine\run(function () use (&$code): void {
        $code = PHPUnit\TextUI\Command::main(false);
        Swoole\Timer::clearAll();
    });

    // Counit::create() (used directly by "case-by-case" style tests, and by
    // Deminy\Counit\TestCase::runBare() for "global style" tests) wraps a callable in a coroutine
    // so other tests can run concurrently while it's sleeping/waiting on IO. If that coroutine's
    // assertion/exception happens *after* it had already yielded once (e.g. after a sleep()
    // call), create() had already returned to its caller by then, so PHPUnit reported the test as
    // passed before the failure actually happened; see Counit::$deferredFailures. Check for that
    // here, once we're back in normal (non-coroutine) PHP -- calling exit() from inside a
    // coroutine gets intercepted by Swoole itself and can't reliably override PHPUnit's own exit
    // code -- and force the run to fail instead of letting that false "pass" stand uncorrected.
    if (!empty(Deminy\Counit\Counit::$deferredFailures)) {
        fwrite(STDERR, PHP_EOL . 'The following failures happened after their test had already been reported as passed' . PHP_EOL . '(the assertion/exception occurred after a sleep()/IO yield point):' . PHP_EOL . PHP_EOL);
        foreach (Deminy\Counit\Counit::$deferredFailures as $testDescription => $throwable) {
            fwrite(STDERR, sprintf('- %s: %s%s', $testDescription, $throwable->getMessage(), PHP_EOL));
        }
        fwrite(STDERR, PHP_EOL);
        $code = 1;
    }

    exit($code);
}

// Swoole is not installed or enabled? Then just run unit tests directly as in PHPUnit!
PHPUnit\TextUI\Command::main();
