# The PHPStan configuration file.
#
# To run static analysis locally with PHPStan, please start the Docker containers first (see the
# "Setup Test Environment" section in README.md), then run:
#     docker compose exec -ti swoole composer global require phpstan/phpstan=^2.0 -n -q --no-progress
#     docker compose exec -ti swoole /root/.composer/vendor/bin/phpstan analyse --no-progress
#
parameters:
  level: 9
  paths:
    - ./src
    - ./tests
  ignoreErrors:
    # The compatibility tests assert literal true on purpose: they exercise how counit
    # counts/suppresses assertions under PHPUnit, not the assertions' own logic.
    -
      identifier: staticMethod.alreadyNarrowedType
      path: tests/unit/compatibility/*
